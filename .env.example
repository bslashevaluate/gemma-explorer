# Setup: conda activate gemma-explorer (see idea.md for env creation)

# Required
HF_TOKEN=

# Optional — enables Neuronpedia integration
NEURONPEDIA_API_KEY=

# Model config
MODEL_NAME=gemma-2-2b
DEVICE=cuda
DTYPE=bfloat16

# SAE config
SAE_RELEASE=gemma-scope-2b-pt-res
SAE_WIDTH=16k
SAE_LAYERS=10,12,14,16,18,20

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
